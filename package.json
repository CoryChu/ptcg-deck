{
  "name": "ptcg-deck",
  "version": "1.3.0",
  "description": "PTCG Deck — 卡牌牌組管理與雷射列印排版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "web": "npx --yes serve . -l 3000",
    "deploy": "npx vercel --prod",
    "deploy:watch": "bash scripts/deploy-watch.sh",
    "sync": "bash scripts/git-push-if-changed.sh",
    "release": "npm run sync && npm run deploy"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "jspdf": "^2.5.2"
  }
}
